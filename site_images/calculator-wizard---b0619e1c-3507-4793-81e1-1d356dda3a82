<script>
/* ─── CALCULATOR ─── */
const prices = {
  wonderware: { name: 'Wonderware InTouch', base: 180000 },
  tia:        { name: 'TIA Portal V18',      base: 95000  },
  kepware:    { name: 'Kepware OPC Server',  base: 145000 },
  genesis:    { name: 'GENESIS64',           base: 210000 },
  citect:     { name: 'Citect SCADA',        base: 160000 },
  ignition:   { name: 'Ignition 8.1',        base: 390000 },
};
const termMult   = [1, 1.8, 2.5];
const addonPrices = { 'addon-install': 45000, 'addon-training': 60000, 'addon-support': 80000, 'addon-integration': 120000 };
const fmt = n => n.toLocaleString('ru-RU');

function calcUpdate() {
  const prod = document.querySelector('input[name=product]:checked').value;
  const qty  = +document.getElementById('qty-slider').value;
  const term = +document.getElementById('term-slider').value;
  const p    = prices[prod];
  const mult = termMult[term - 1];

  // Volume discount
  let disc = 0;
  if (qty >= 20) disc = 0.20;
  else if (qty >= 10) disc = 0.10;
  else if (qty >= 5) disc = 0.05;

  let licPrice = Math.round(p.base * qty * mult);
  const discAmt = Math.round(licPrice * disc);
  licPrice -= discAmt;

  let addons = 0;
  Object.keys(addonPrices).forEach(id => {
    if (document.getElementById(id).checked) addons += addonPrices[id];
  });
  const total = licPrice + addons;

  document.getElementById('r-product').textContent = p.name;
  document.getElementById('r-qty').textContent = qty + ' шт.';
  document.getElementById('r-unit').textContent = fmt(p.base) + ' ₽';
  const terms = ['1 год', '2 года', '3 года'];
  document.getElementById('r-term').textContent = terms[term - 1];
  document.getElementById('r-lic').textContent = fmt(licPrice + discAmt) + ' ₽';

  const discRow = document.getElementById('r-discount-row');
  const discBan = document.getElementById('r-discount-banner');
  if (discAmt > 0) {
    discRow.style.display = 'flex';
    discBan.style.display = 'flex';
    document.getElementById('r-discount').textContent = '−' + fmt(discAmt) + ' ₽';
    document.getElementById('r-discount-text').textContent =
      `Скидка за объём ${Math.round(disc*100)}% применена (-${fmt(discAmt)} ₽)`;
  } else {
    discRow.style.display = 'none';
    discBan.style.display = 'none';
  }

  const addRow = document.getElementById('r-addons-row');
  if (addons > 0) {
    addRow.style.display = 'flex';
    document.getElementById('r-addons').textContent = '+' + fmt(addons) + ' ₽';
  } else {
    addRow.style.display = 'none';
  }

  document.getElementById('r-total').innerHTML = fmt(total) + '<span>₽</span>';

  // Update date
  const now = new Date();
  document.getElementById('r-date').textContent =
    now.toLocaleDateString('ru-RU', { day:'numeric', month:'long', year:'numeric' });
}

calcUpdate();

/* ─── TABS ─── */
function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  btn.classList.add('active');
}

/* ─── WIZARD ─── */
let currentStep = 1;
const totalSteps = 4;

function updateWizardUI() {
  // Panels
  for (let i = 1; i <= totalSteps; i++) {
    const sp = document.getElementById('sp-' + i);
    const sh = document.getElementById('wiz-head-' + i);
    if (sp) sp.classList.toggle('active', i === currentStep);
    if (sh) sh.style.display = i === currentStep ? 'block' : 'none';
  }
  // Sidebar
  for (let i = 1; i <= totalSteps; i++) {
    const si = document.getElementById('si-' + i);
    if (!si) continue;
    si.classList.remove('active', 'done');
    if (i < currentStep) si.classList.add('done');
    else if (i === currentStep) si.classList.add('active');
  }
  // Progress
  const pct = Math.round((currentStep / totalSteps) * 100);
  document.getElementById('wiz-pct').textContent = pct + '%';
  document.getElementById('wiz-bar').style.width = pct + '%';
  // Buttons
  const back = document.getElementById('btn-back');
  const next = document.getElementById('btn-next');
  if (back) back.style.display = currentStep > 1 ? 'inline-flex' : 'none';
  if (next) {
    if (currentStep === totalSteps) {
      next.textContent = '✓ Отправить КП';
      next.className = 'btn btn-sm btn-flame';
    } else {
      next.innerHTML = 'Далее →';
      next.className = 'btn btn-sm btn-volt';
    }
  }
  // Note
  document.getElementById('wf-note').innerHTML =
    `Шаг ${currentStep} из ${totalSteps} · Поля <span style="color:var(--volt)">*</span> обязательны`;
}

function goToStep(n) {
  currentStep = n;
  updateWizardUI();
}

function wizStep(dir) {
  if (dir === 1 && currentStep === totalSteps) {
    // Submit
    fillSummaryBeforeSend();
    submitWizard();
    return;
  }
  if (dir === 1 && currentStep === totalSteps - 1) fillSummary();
  currentStep = Math.max(1, Math.min(totalSteps, currentStep + dir));
  updateWizardUI();
  document.querySelector('.wizard-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function fillSummary() {
  const catMap = { scada:'SCADA', plc:'ПЛК / IDE', hmi:'HMI', opc:'Сети / OPC', mes:'MES / ERP', eng:'Инж. ПО / CAD' };
  const cat = document.querySelector('input[name=wiz-cat]:checked')?.value || 'scada';
  const urg = document.querySelector('input[name=urgency]:checked')?.value || 'asap';
  const urgMap = { asap:'🔴 ASAP (24–48 ч)', week:'🟠 Неделя (3–7 дней)', month:'🟡 Месяц', plan:'🟢 Плановый' };
  const licSel = document.querySelector('.wiz-select');
  document.getElementById('s-cat').textContent     = catMap[cat] || cat;
  document.getElementById('s-product').textContent = document.getElementById('wiz-product-name').value || '—';
  document.getElementById('s-qty').textContent     = (document.getElementById('wiz-qty').value || '—') + ' шт.';
  document.getElementById('s-lictype').textContent = licSel ? licSel.value : 'Бессрочная';
  document.getElementById('s-urgency').textContent = urgMap[urg] || urg;
  document.getElementById('s-name').textContent    = document.getElementById('wiz-name').value || '—';
  document.getElementById('s-email').textContent   = document.getElementById('wiz-email').value || '—';
  document.getElementById('s-company').textContent = document.getElementById('wiz-company').value || '—';
}

function fillSummaryBeforeSend() { fillSummary(); }

function submitWizard() {
  const card    = document.getElementById('wizard-form-card');
  const success = document.getElementById('success-state');
  const footer  = document.getElementById('wiz-footer');
  // Hide all step panels & heads & footer
  for (let i = 1; i <= totalSteps; i++) {
    const sp = document.getElementById('sp-' + i);
    const sh = document.getElementById('wiz-head-' + i);
    if (sp) sp.style.display = 'none';
    if (sh) sh.style.display = 'none';
  }
  if (footer) footer.style.display = 'none';
  // Ticket ID
  const tid = 'КП-' + new Date().getFullYear() + '-' + Math.floor(1000 + Math.random() * 9000);
  document.getElementById('ticket-id').textContent = tid;
  success.classList.add('show');
  // Update sidebar — all done
  for (let i = 1; i <= totalSteps; i++) {
    const si = document.getElementById('si-' + i);
    if (si) { si.classList.remove('active'); si.classList.add('done'); }
  }
  document.getElementById('wiz-pct').textContent = '100%';
  document.getElementById('wiz-bar').style.width = '100%';
}

function resetWizard() {
  currentStep = 1;
  document.getElementById('success-state').classList.remove('show');
  for (let i = 1; i <= totalSteps; i++) {
    const sp = document.getElementById('sp-' + i);
    const sh = document.getElementById('wiz-head-' + i);
    if (sp) sp.style.display = '';
    if (sh) sh.style.display = '';
  }
  document.getElementById('wiz-footer').style.display = '';
  updateWizardUI();
}

function prefillWizard() {
  // Switch to wizard and open it
  setTimeout(() => {
    const prod = document.querySelector('input[name=product]:checked').value;
    const p = prices[prod];
    const qtyEl = document.getElementById('wiz-product-name');
    if (qtyEl) qtyEl.value = p.name;
    const qtyNum = document.getElementById('wiz-qty');
    if (qtyNum) qtyNum.value = document.getElementById('qty-slider').value;
  }, 100);
}

updateWizardUI();
</script>
