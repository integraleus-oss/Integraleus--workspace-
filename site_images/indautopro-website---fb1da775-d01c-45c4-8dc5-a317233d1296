══════════════════════════════════════ */
.testimonials {
  padding: 100px 0;
  background: var(--ink1);
  border-top: 1px solid var(--wire);
  overflow: hidden;
}
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 60px;
}
.testi-card {
  background: var(--ink);
  border: 1px solid var(--wire);
  padding: 28px;
  position: relative;
  transition: border-color .2s;
}
.testi-card:hover { border-color: var(--wire2); }
.testi-quote {
  font-size: 36px;
  color: var(--volt);
  font-family: Georgia, serif;
  line-height: 1;
  margin-bottom: 16px;
  opacity: 0.5;
}
.testi-text {
  font-size: 14px;
  font-weight: 300;
  color: var(--text2);
  line-height: 1.7;
  margin-bottom: 24px;
}
.testi-author { display: flex; align-items: center; gap: 14px; }
.testi-avatar {
  width: 40px;
  height: 40px;
  background: var(--steel);
  border: 1px solid var(--wire2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  color: var(--volt);
  flex-shrink: 0;
}
.testi-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 0.5px;
}
.testi-pos {
  font-family: var(--ff-mono);
  font-size: 10px;
  color: var(--text3);
  margin-top: 2px;
}
.testi-stars {
  position: absolute;
  top: 24px;
  right: 24px;
  display: flex;
  gap: 3px;
}
.star { color: var(--amber); font-size: 12px; }

/* ══════════════════════════════════════
   CTA SECTION
══════════════════════════════════════ */
.cta-section {
  padding: 120px 0;
  position: relative;
  overflow: hidden;
}
.cta-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 50% 50%, rgba(0,200,240,0.06) 0%, transparent 70%);
}
.cta-grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--wire) 1px, transparent 1px),
    linear-gradient(90deg, var(--wire) 1px, transparent 1px);
  background-size: 60px 60px;
  opacity: 0.2;
}
.cta-inner {
  position: relative;
  z-index: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}
.cta-sup {
  font-family: var(--ff-mono);
  font-size: 11px;
  letter-spacing: 4px;
  color: var(--volt);
  text-transform: uppercase;
}
.cta-title {
  font-size: clamp(32px, 5vw, 64px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -1px;
  color: var(--text);
  line-height: 1;
}
.cta-title span { color: var(--volt); }
.cta-sub {
  font-size: 16px;
  font-weight: 300;
  color: var(--text2);
  max-width: 480px;
  line-height: 1.6;
}
.cta-btns { display: flex; gap: 16px; align-items: center; margin-top: 8px; }

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
footer {
  background: var(--ink1);
  border-top: 1px solid var(--wire);
