<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ИНДАВТОПРО — Программное обеспечение для промышленной автоматизации</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   ROOT TOKENS
══════════════════════════════════════ */
:root {
  --ink:        #05080f;
  --ink1:       #080d1a;
  --ink2:       #0c1525;
  --steel:      #111e35;
  --wire:       #192d48;
  --wire2:      #1f3a5f;

  --volt:       #00c8f0;
  --volt-lo:    rgba(0,200,240,0.08);
  --volt-glow:  rgba(0,200,240,0.4);
  --flame:      #ff6b35;
  --flame-lo:   rgba(255,107,53,0.1);
  --lime:       #1de9b6;
  --lime-lo:    rgba(29,233,182,0.08);
  --crimson:    #ff3d57;
  --amber:      #ffb800;

  --text:       #ccd9ea;
  --text2:      #6a8aaa;
  --text3:      #2d4a6a;

  --ff-head:    'Exo 2', sans-serif;
  --ff-mono:    'JetBrains Mono', monospace;

  --ease:       cubic-bezier(.22,.68,0,1.2);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--ink);
  color: var(--text);
  font-family: var(--ff-head);
  overflow-x: hidden;
  cursor: default;
}

/* ── scrollbar ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--ink1); }
::-webkit-scrollbar-thumb { background: var(--wire2); border-radius: 2px; }

/* ══════════════════════════════════════
   NOISE OVERLAY
══════════════════════════════════════ */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    repeating-linear-gradient(0deg,  transparent, transparent 59px, rgba(25,45,72,0.12) 60px),
    repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(25,45,72,0.12) 60px);
  pointer-events: none;
  z-index: 0;
}

/* ══════════════════════════════════════
   NAV
══════════════════════════════════════ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48px;
  height: 64px;
  background: rgba(5,8,15,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--wire);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}
.nav-logo-mark {
  width: 32px;
  height: 32px;
  background: var(--volt);
  clip-path: polygon(0 30%, 50% 0, 100% 30%, 100% 70%, 50% 100%, 0 70%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}
.nav-logo-mark::after {
  content: '';
  position: absolute;
  inset: 4px;
  background: var(--ink);
  clip-path: polygon(0 30%, 50% 0, 100% 30%, 100% 70%, 50% 100%, 0 70%);
}
.nav-logo-text {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text);
}
.nav-logo-text span { color: var(--volt); }

.nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
  list-style: none;
}
.nav-links a {
  text-decoration: none;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
  transition: color .2s;
  position: relative;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0; right: 0;
  height: 1px;
  background: var(--volt);
  transform: scaleX(0);
  transition: transform .2s;
}
.nav-links a:hover { color: var(--volt); }
.nav-links a:hover::after { transform: scaleX(1); }

.nav-cta {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* ══════════════════════════════════════
   BUTTONS
══════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--ff-head);
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: all .2s;
  text-decoration: none;
  white-space: nowrap;
}

.btn-volt {
  background: var(--volt);
  color: var(--ink);
  padding: 11px 24px;
  font-size: 12px;
  clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  box-shadow: 0 0 24px var(--volt-glow);
}
.btn-volt:hover {
  background: #33d5f7;
  box-shadow: 0 0 40px var(--volt-glow);
  transform: translateY(-1px);
}

.btn-outline {
  background: transparent;
  color: var(--volt);
  padding: 10px 22px;
  font-size: 12px;
  border: 1px solid var(--volt);
  clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  box-shadow: inset 0 0 16px var(--volt-lo);
}
.btn-outline:hover {
  background: var(--volt-lo);
  box-shadow: 0 0 24px var(--volt-lo), inset 0 0 20px var(--volt-lo);
  transform: translateY(-1px);
}

.btn-flame {
  background: var(--flame);
  color: #fff;
  padding: 14px 32px;
  font-size: 14px;
  clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  box-shadow: 0 0 30px rgba(255,107,53,0.4);
}
.btn-flame:hover {
  background: #ff8054;
  box-shadow: 0 0 50px rgba(255,107,53,0.5);
  transform: translateY(-2px);
}

.btn-lg {
  padding: 16px 42px;
  font-size: 14px;
}

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120px 48px 80px;
  overflow: hidden;
}

/* Animated grid bg */
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--wire) 1px, transparent 1px),
    linear-gradient(90deg, var(--wire) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);
  opacity: 0.25;
}

/* Glowing orb */
.hero-orb {
  position: absolute;
  top: -20%;
  right: -10%;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,200,240,0.07) 0%, rgba(0,200,240,0.03) 40%, transparent 70%);
  animation: orb-pulse 6s ease-in-out infinite;
}
@keyframes orb-pulse {
  0%,100% { transform: scale(1); opacity: 1; }
  50%      { transform: scale(1.08); opacity: 0.7; }
}

/* Diagonal accent line */
.hero::after {
  content: '';
  position: absolute;
  top: 0;
  right: 180px;
  width: 1px;
  height: 100%;
  background: linear-gradient(to bottom, transparent, var(--volt) 30%, var(--volt) 70%, transparent);
  opacity: 0.15;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 28px;
  animation: slide-up .7s var(--ease) both;
}
.hero-eyebrow-line {
  width: 40px;
  height: 1px;
  background: var(--volt);
  box-shadow: 0 0 8px var(--volt-glow);
}
.hero-eyebrow span {
  font-family: var(--ff-mono);
  font-size: 11px;
  color: var(--volt);
  letter-spacing: 3px;
  text-transform: uppercase;
}

.hero-title {
  font-size: clamp(42px, 6vw, 88px);
  font-weight: 900;
  line-height: 0.95;
  letter-spacing: -1px;
  text-transform: uppercase;
  color: var(--text);
  max-width: 780px;
  animation: slide-up .7s .1s var(--ease) both;
}
.hero-title .accent { color: var(--volt); }
.hero-title .outline {
  -webkit-text-stroke: 1px var(--text2);
  color: transparent;
}

.hero-sub {
  font-size: 17px;
  font-weight: 300;
  color: var(--text2);
  line-height: 1.7;
  max-width: 520px;
  margin-top: 28px;
  animation: slide-up .7s .2s var(--ease) both;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 44px;
  flex-wrap: wrap;
  animation: slide-up .7s .3s var(--ease) both;
}

/* Live ticker */
.hero-ticker {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  height: 40px;
  background: var(--steel);
  border-top: 1px solid var(--wire);
  overflow: hidden;
  display: flex;
  align-items: center;
}
.ticker-inner {
  display: flex;
  gap: 60px;
  animation: ticker 28s linear infinite;
  white-space: nowrap;
}
@keyframes ticker { to { transform: translateX(-50%); } }
.ticker-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--ff-mono);
  font-size: 11px;
  color: var(--text3);
}
.ticker-item .t-name { color: var(--text2); }
.ticker-item .t-val  { color: var(--lime); }
.ticker-item .t-dot  { width: 5px; height: 5px; border-radius: 50%; background: var(--lime); }

/* Hero stat pills */
.hero-stats {
  position: absolute;
  right: 48px;
  bottom: 80px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  animation: slide-up .7s .4s var(--ease) both;
}
.stat-pill {
  background: var(--steel);
  border: 1px solid var(--wire);
  border-left: 3px solid var(--volt);
  padding: 12px 18px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 160px;
}
.stat-num {
  font-size: 28px;
  font-weight: 800;
  color: var(--text);
  line-height: 1;
}
.stat-num span { font-size: 16px; color: var(--volt); }
.stat-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
}

/* ══════════════════════════════════════
   SECTION COMMONS
══════════════════════════════════════ */
section { position: relative; z-index: 1; }

.container { max-width: 1180px; margin: 0 auto; padding: 0 48px; }

.section-tag {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}
.section-tag::before {
  content: '';
  display: block;
  width: 24px;
  height: 2px;
  background: var(--volt);
  box-shadow: 0 0 6px var(--volt-glow);
}
.section-tag span {
  font-family: var(--ff-mono);
  font-size: 11px;
  color: var(--volt);
  letter-spacing: 3px;
  text-transform: uppercase;
}

.section-title {
  font-size: clamp(28px, 4vw, 52px);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--text);
}
.section-title span { color: var(--volt); }

/* ══════════════════════════════════════
   PARTNERS / LOGOS STRIP
══════════════════════════════════════ */
.partners {
  padding: 48px 0;
  background: var(--ink1);
  border-top: 1px solid var(--wire);
  border-bottom: 1px solid var(--wire);
  overflow: hidden;
}
.partners-label {
  text-align: center;
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 4px;
  color: var(--text3);
  text-transform: uppercase;
  margin-bottom: 28px;
}
.partners-scroll {
  display: flex;
  gap: 60px;
  animation: ticker 20s linear infinite;
  width: max-content;
}
.partner-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  opacity: 0.4;
  transition: opacity .2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.partner-logo:hover { opacity: 0.8; }
.partner-logo-icon {
  width: 28px;
  height: 28px;
  border: 1px solid var(--wire2);
  background: var(--steel);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--ff-mono);
  font-size: 10px;
  font-weight: 500;
  color: var(--text2);
}
.partner-logo-name {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
}

/* ══════════════════════════════════════
   PRODUCTS
══════════════════════════════════════ */
.products { padding: 100px 0; }

.products-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-top: 60px;
  background: var(--wire);
}

.product-card {
  background: var(--ink1);
  padding: 36px 32px;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: background .25s;
}
.product-card:hover { background: var(--ink2); }

/* Top accent */
.product-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--wire2);
  transition: background .25s, box-shadow .25s;
}
.product-card:hover::before {
  background: var(--volt);
  box-shadow: 0 0 12px var(--volt-glow);
}

/* Hover glow */
.product-card::after {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 120px; height: 120px;
  border-radius: 50%;
  background: var(--volt-lo);
  opacity: 0;
  transition: opacity .3s;
}
.product-card:hover::after { opacity: 1; }

.product-num {
  font-family: var(--ff-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 2px;
  margin-bottom: 20px;
}

.product-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}

.product-name {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text);
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
}

.product-desc {
  font-size: 14px;
  font-weight: 300;
  color: var(--text2);
  line-height: 1.6;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}
.ptag {
  font-family: var(--ff-mono);
  font-size: 9px;
  padding: 3px 8px;
  border: 1px solid var(--wire2);
  color: var(--text3);
  letter-spacing: 1px;
  transition: border-color .2s, color .2s;
}
.product-card:hover .ptag { border-color: var(--volt); color: var(--volt); }

.product-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--volt);
  text-decoration: none;
  position: relative;
  z-index: 1;
  transition: gap .2s;
}
.product-link:hover { gap: 14px; }
.product-link svg { transition: transform .2s; }
.product-link:hover svg { transform: translateX(4px); }

/* ══════════════════════════════════════
   FEATURES (WHY US)
══════════════════════════════════════ */
.features {
  padding: 100px 0;
  background: var(--ink1);
  border-top: 1px solid var(--wire);
  border-bottom: 1px solid var(--wire);
}

.features-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-top: 60px;
}

.features-visual {
  position: relative;
}

/* Terminal window mock */
.terminal {
  background: var(--ink);
  border: 1px solid var(--wire2);
  border-radius: 4px;
  overflow: hidden;
  box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,200,240,0.05);
}
.terminal-bar {
  background: var(--steel);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid var(--wire);
}
.t-dot { width: 10px; height: 10px; border-radius: 50%; }
.t-dot-r { background: var(--crimson); opacity: 0.6; }
.t-dot-y { background: var(--amber); opacity: 0.6; }
.t-dot-g { background: var(--lime); opacity: 0.6; }
.terminal-title {
  font-family: var(--ff-mono);
  font-size: 11px;
  color: var(--text3);
  margin-left: auto;
  letter-spacing: 1px;
}
.terminal-body {
  padding: 24px;
  font-family: var(--ff-mono);
  font-size: 12px;
  line-height: 2;
}
.tl { display: flex; gap: 12px; }
.tl-prompt { color: var(--lime); flex-shrink: 0; }
.tl-cmd    { color: var(--text); }
.tl-out    { color: var(--text2); padding-left: 20px; }
.tl-ok     { color: var(--lime); }
.tl-warn   { color: var(--amber); }
.tl-err    { color: var(--crimson); }
.tl-volt   { color: var(--volt); }
.cursor {
  display: inline-block;
  width: 8px; height: 14px;
  background: var(--volt);
  animation: blink-c .9s step-end infinite;
  vertical-align: middle;
}
@keyframes blink-c { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

/* Floating badge on terminal */
.terminal-badge {
  position: absolute;
  bottom: -20px;
  right: -20px;
  background: var(--steel);
  border: 1px solid var(--wire2);
  border-left: 3px solid var(--lime);
  padding: 14px 20px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.tb-label { font-family: var(--ff-mono); font-size: 9px; color: var(--text3); letter-spacing: 2px; margin-bottom: 4px; }
.tb-val   { font-size: 22px; font-weight: 800; color: var(--lime); }

.features-list { display: flex; flex-direction: column; gap: 32px; }

.feat-item { display: flex; gap: 20px; align-items: flex-start; }
.feat-icon-wrap {
  width: 44px;
  height: 44px;
  background: var(--steel);
  border: 1px solid var(--wire2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}
.feat-icon-wrap::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: var(--volt);
  opacity: 0.5;
}
.feat-body {}
.feat-name {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text);
  margin-bottom: 6px;
}
.feat-desc {
  font-size: 14px;
  font-weight: 300;
  color: var(--text2);
  line-height: 1.65;
}

/* ══════════════════════════════════════
   CATALOG CATEGORIES
══════════════════════════════════════ */
.catalog { padding: 100px 0; }

.catalog-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-top: 60px;
}

.cat-card {
  background: var(--ink1);
  border: 1px solid var(--wire);
  padding: 28px 24px;
  position: relative;
  cursor: pointer;
  transition: border-color .2s, transform .2s, box-shadow .2s;
  text-decoration: none;
  display: block;
  overflow: hidden;
  group: true;
}

.cat-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: var(--volt);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s;
}

.cat-card:hover {
  border-color: var(--wire2);
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.5);
}
.cat-card:hover::after { transform: scaleX(1); }

.cat-card-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, var(--volt-lo), transparent 70%);
  opacity: 0;
  transition: opacity .3s;
}
.cat-card:hover .cat-card-bg { opacity: 1; }

.cat-icon { margin-bottom: 20px; position: relative; z-index: 1; }
.cat-count {
  position: absolute;
  top: 16px; right: 16px;
  font-family: var(--ff-mono);
  font-size: 10px;
  color: var(--text3);
}
.cat-name {
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text);
  margin-bottom: 8px;
  position: relative;
  z-index: 1;
  transition: color .2s;
}
.cat-card:hover .cat-name { color: var(--volt); }
.cat-sub {
  font-size: 13px;
  font-weight: 300;
  color: var(--text2);
  line-height: 1.5;
  position: relative;
  z-index: 1;
}

/* ══════════════════════════════════════
   METRICS ROW
══════════════════════════════════════ */
.metrics {
  padding: 0 0 100px;
}
.metrics-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  background: var(--wire);
  border: 1px solid var(--wire);
}
.metric-block {
  background: var(--ink1);
  padding: 40px 32px;
  text-align: center;
}
.metric-val {
  font-size: 52px;
  font-weight: 900;
  color: var(--text);
  line-height: 1;
  margin-bottom: 8px;
}
.metric-val .u { font-size: 28px; color: var(--volt); }
.metric-name {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
  margin-bottom: 4px;
}
.metric-note {
  font-family: var(--ff-mono);
  font-size: 10px;
  color: var(--text3);
}

/* ══════════════════════════════════════
