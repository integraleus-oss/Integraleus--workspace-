      <!-- редуктор -->
      <rect x="36" y="20" width="10" height="12" rx="1.5" fill="rgba(176,136,255,0.1)" stroke="#5522aa" stroke-width="1"/>
      <!-- шестерня -->
      <circle cx="41" cy="26" r="3.5" stroke="#b088ff" stroke-width="1" fill="rgba(176,136,255,0.2)" class="spin"/>
