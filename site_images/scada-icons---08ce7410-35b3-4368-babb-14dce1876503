<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SCADA / АСУ ТП — Иконки</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e14;
    --surface: #0f1520;
    --card: #121a28;
    --border: #1e2d45;
    --accent: #00c8ff;
    --accent2: #00ff9d;
    --accent3: #ff6b35;
    --accent4: #f0c040;
    --text: #c8ddf5;
    --muted: #4a6080;
    --glow: rgba(0,200,255,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Exo 2', sans-serif;
    min-height: 100vh;
    padding: 40px 24px;
    background-image:
      linear-gradient(rgba(0,200,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,200,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  header {
    text-align: center;
    margin-bottom: 56px;
  }

  .label-top {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.8;
  }

  h1 {
    font-size: clamp(24px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #fff 30%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .subtitle {
    margin-top: 10px;
    font-size: 14px;
    color: var(--muted);
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .section-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--accent);
    text-transform: uppercase;
    margin: 48px 0 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border), transparent);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 16px;
  }

  .icon-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 16px 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .icon-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, var(--glow), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .icon-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 24px rgba(0,200,255,0.12), 0 4px 24px rgba(0,0,0,0.4);
    transform: translateY(-3px);
  }
  .icon-card:hover::before { opacity: 1; }

  .icon-card svg {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
  }

  .icon-name {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text);
    text-align: center;
    line-height: 1.4;
  }

  .icon-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    text-align: center;
    letter-spacing: 0.05em;
  }

  /* COLOR VARIANTS */
  .c-blue  { --ic: #00c8ff; --ig: #0066aa; }
  .c-green { --ic: #00ff9d; --ig: #007744; }
  .c-orange{ --ic: #ff6b35; --ig: #aa3300; }
  .c-yellow{ --ic: #f0c040; --ig: #886600; }
  .c-violet{ --ic: #b088ff; --ig: #5522aa; }
  .c-red   { --ic: #ff4466; --ig: #880022; }

  .icon-card.c-blue:hover   { border-color: #00c8ff; box-shadow: 0 0 24px rgba(0,200,255,0.15), 0 4px 24px rgba(0,0,0,0.4); }
  .icon-card.c-green:hover  { border-color: #00ff9d; box-shadow: 0 0 24px rgba(0,255,157,0.12), 0 4px 24px rgba(0,0,0,0.4); }
  .icon-card.c-orange:hover { border-color: #ff6b35; box-shadow: 0 0 24px rgba(255,107,53,0.15), 0 4px 24px rgba(0,0,0,0.4); }
  .icon-card.c-yellow:hover { border-color: #f0c040; box-shadow: 0 0 24px rgba(240,192,64,0.15), 0 4px 24px rgba(0,0,0,0.4); }
  .icon-card.c-violet:hover { border-color: #b088ff; box-shadow: 0 0 24px rgba(176,136,255,0.15), 0 4px 24px rgba(0,0,0,0.4); }
  .icon-card.c-red:hover    { border-color: #ff4466; box-shadow: 0 0 24px rgba(255,68,102,0.15), 0 4px 24px rgba(0,0,0,0.4); }

  /* Pulse animation for status icons */
  @keyframes pulse-ring {
    0%   { transform: scale(0.92); opacity: 1; }
    100% { transform: scale(1.08); opacity: 0; }
  }
  .pulse-dot {
    animation: pulse-ring 1.8s cubic-bezier(0.4,0,0.6,1) infinite;
    transform-origin: center;
  }

  /* Spin animation */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .spin { animation: spin-slow 8s linear infinite; transform-origin: center; }

  /* Blink */
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .blink { animation: blink 2s ease-in-out infinite; }

  /* Flow */
  @keyframes flow { 0%{stroke-dashoffset:40} 100%{stroke-dashoffset:0} }
  .flow { animation: flow 2s linear infinite; }

  .footer {
    text-align: center;
    margin-top: 64px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.15em;
  }
</style>
</head>
<body>

<header>
  <div class="label-top">// icon system v1.0</div>
  <h1>SCADA · АСУ ТП · Инженерный Софт</h1>
  <p class="subtitle">Профессиональный набор иконок для промышленных систем управления</p>
</header>

<!-- ═══════════════════════════════════════════════ МОНИТОРИНГ -->
<div class="section-title">// мониторинг и контроль</div>
<div class="grid">

  <!-- HMI Панель -->
