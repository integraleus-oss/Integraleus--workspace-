      <circle cx="26" cy="26" r="2.5" fill="#00ff9d"/>
    </svg>
    <div>
      <div class="icon-name">Статус системы</div>
      <div class="icon-sub">System Status</div>
    </div>
  </div>

</div>

<!-- ═══════════════════════════════════════════════ ОБОРУДОВАНИЕ -->
<div class="section-title">// полевое оборудование и КИП</div>
<div class="grid">

  <!-- ПЛК / PLC -->
