      <circle cx="26" cy="24" r="12" stroke="#aa3300" stroke-width="0.5"/>
      <!-- шкала -->
      <line x1="26" y1="12" x2="26" y2="15" stroke="#ff6b35" stroke-width="1.5"/>
      <line x1="36.9" y1="16.9" x2="34.8" y2="18.7" stroke="#ff6b35" stroke-width="1.5"/>
      <line x1="14" y1="17" x2="16" y2="19" stroke="#ff6b35" stroke-width="1.5"/>
