      <rect x="4" y="8" width="44" height="30" rx="3" stroke="#00c8ff" stroke-width="1.5" fill="rgba(0,200,255,0.05)"/>
      <rect x="8" y="12" width="36" height="22" rx="1.5" fill="rgba(0,200,255,0.08)" stroke="#0066aa" stroke-width="1"/>
