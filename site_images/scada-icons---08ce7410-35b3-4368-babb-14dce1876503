      <text x="13" y="13.5" fill="#f0c040" font-size="5" font-family="Share Tech Mono, monospace" opacity="0.8">LOG</text>
    </svg>
    <div>
      <div class="icon-name">Журнал событий</div>
      <div class="icon-sub">Event Log</div>
    </div>
  </div>

  <!-- Статус системы -->
  <div class="icon-card c-green">
    <svg viewBox="0 0 52 52" fill="none">
      <circle cx="26" cy="26" r="18" stroke="#1e2d45" stroke-width="1.5" fill="rgba(0,255,157,0.04)"/>
      <!-- секторы статуса -->
      <path d="M26 26 L26 10 A16 16 0 0 1 39.86 18 Z" fill="rgba(0,255,157,0.3)" stroke="#00ff9d" stroke-width="0.5"/>
      <path d="M26 26 L39.86 18 A16 16 0 0 1 39.86 34 Z" fill="rgba(0,255,157,0.15)" stroke="#00ff9d" stroke-width="0.5"/>
      <path d="M26 26 L39.86 34 A16 16 0 0 1 12.14 34 Z" fill="rgba(0,255,157,0.08)" stroke="#007744" stroke-width="0.5"/>
      <path d="M26 26 L12.14 34 A16 16 0 0 1 12.14 18 Z" fill="rgba(240,192,64,0.15)" stroke="#886600" stroke-width="0.5"/>
      <path d="M26 26 L12.14 18 A16 16 0 0 1 26 10 Z" fill="rgba(255,107,53,0.1)" stroke="#aa3300" stroke-width="0.5"/>
