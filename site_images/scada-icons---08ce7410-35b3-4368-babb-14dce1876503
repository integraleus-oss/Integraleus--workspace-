      <line x1="28" y1="43" x2="34" y2="43" stroke="#007744" stroke-width="1.2" opacity="0.6"/>
    </svg>
    <div>
      <div class="icon-name">Тренды</div>
      <div class="icon-sub">Real-time Charts</div>
    </div>
  </div>

  <!-- Аварийная сигнализация -->
  <div class="icon-card c-red">
    <svg viewBox="0 0 52 52" fill="none">
      <circle cx="26" cy="26" r="18" stroke="rgba(255,68,102,0.2)" stroke-width="6" class="pulse-dot"/>
      <circle cx="26" cy="26" r="15" stroke="#ff4466" stroke-width="1.5" fill="rgba(255,68,102,0.06)"/>
      <path d="M18 32 L26 14 L34 32 Z" stroke="#ff4466" stroke-width="1.5" fill="rgba(255,68,102,0.15)" stroke-linejoin="round"/>
      <line x1="26" y1="22" x2="26" y2="28" stroke="#ff4466" stroke-width="2" stroke-linecap="round" class="blink"/>
