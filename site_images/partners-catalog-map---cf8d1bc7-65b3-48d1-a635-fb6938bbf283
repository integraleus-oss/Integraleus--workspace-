<script>
function showView(id, btn) {
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.ntab').forEach(b=>b.classList.remove('active'));
  document.getElementById('view-'+id).classList.add('active');
  btn.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}
function toggleGroup(el) {
  el.classList.toggle('open');
}
function filterProducts() {
  const q = (document.getElementById('catalog-search-input')?.value||'').toLowerCase();
  const rows = document.querySelectorAll('.prod-row');
  let vis = 0;
  rows.forEach(r=>{
    const txt = r.textContent.toLowerCase();
    const show = !q || txt.includes(q);
    r.style.display = show ? '' : 'none';
    if(show) vis++;
  });
  const cnt = document.getElementById('catalog-count');
  if(cnt) cnt.textContent = 'Найдено: '+vis;
}
function resetFilters() {
  document.querySelectorAll('.filter-check input').forEach(i=>i.checked=false);
  const si = document.getElementById('catalog-search-input');
  if(si) si.value='';
  filterProducts();
}

// Map tooltip
function showTip(e, city, count, projects) {
  const tt = document.getElementById('map-tooltip');
  document.getElementById('tt-city').textContent = city;
  document.getElementById('tt-count').textContent = count;
  const pl = document.getElementById('tt-projects');
  pl.innerHTML = projects.map(p=>`<div class="tt-project">· ${p}</div>`).join('');
  const wrap = tt.closest('.map-svg-wrap');
  const wr = wrap.getBoundingClientRect();
  const x = e.clientX - wr.left + 12;
  const y = e.clientY - wr.top - 10;
  tt.style.left = Math.min(x, wr.width-200)+'px';
  tt.style.top  = Math.max(y-80, 8)+'px';
  tt.classList.add('show');
}
function hideTip() {
  document.getElementById('map-tooltip').classList.remove('show');
}
</script>
