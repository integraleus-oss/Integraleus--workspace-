<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Партнёры · Каталог · Карта — ИндАвтоПро</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink:      #05080f; --ink1: #080d1a; --ink2: #0c1525; --steel: #111e35;
  --wire:     #192d48; --wire2: #1f3a5f;
  --volt:     #00c8f0; --volt-lo: rgba(0,200,240,0.08); --volt-med: rgba(0,200,240,0.15); --volt-glow: rgba(0,200,240,0.35);
  --flame:    #ff6b35; --flame-lo: rgba(255,107,53,0.1);
  --lime:     #1de9b6; --lime-lo: rgba(29,233,182,0.08);
  --crimson:  #ff3d57; --amber: #ffb800; --violet: #a78bfa;
  --text:     #ccd9ea; --text2: #6a8aaa; --text3: #2d4a6a;
  --ff: 'Exo 2',sans-serif; --mono: 'JetBrains Mono',monospace;
  --ease: cubic-bezier(.22,.68,0,1.2);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--ink);color:var(--text);font-family:var(--ff);overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 59px,rgba(25,45,72,0.1) 60px),repeating-linear-gradient(90deg,transparent,transparent 59px,rgba(25,45,72,0.1) 60px);pointer-events:none;z-index:0;}
::-webkit-scrollbar{width:4px;} ::-webkit-scrollbar-track{background:var(--ink1);} ::-webkit-scrollbar-thumb{background:var(--wire2);border-radius:2px;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:60px;background:rgba(5,8,15,0.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--wire);}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo-hex{width:26px;height:26px;background:var(--volt);clip-path:polygon(0 30%,50% 0,100% 30%,100% 70%,50% 100%,0 70%);position:relative;}
.logo-hex::after{content:'';position:absolute;inset:4px;background:var(--ink);clip-path:polygon(0 30%,50% 0,100% 30%,100% 70%,50% 100%,0 70%);}
.logo-text{font-size:15px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:var(--text);}
.logo-text span{color:var(--volt);}
.nav-tabs{display:flex;gap:2px;}
.ntab{padding:8px 16px;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);cursor:pointer;background:transparent;border:1px solid transparent;border-radius:3px;transition:all .2s;white-space:nowrap;}
.ntab:hover{color:var(--text);border-color:var(--wire);}
.ntab.active{color:var(--volt);border-color:var(--volt);background:var(--volt-lo);}

/* PAGE */
.page{position:relative;z-index:1;padding-top:60px;}
.view{display:none;} .view.active{display:block;animation:fadeUp .3s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.container{max-width:1160px;margin:0 auto;padding:0 40px;}

/* ── COMMON HERO ── */
.page-hero{padding:52px 0 44px;background:var(--ink1);border-bottom:1px solid var(--wire);position:relative;overflow:hidden;}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 100% at 0% 50%,rgba(0,200,240,0.05),transparent 60%);}
.hero-inner{position:relative;z-index:1;}
.hero-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.hero-eyebrow::before{content:'';width:24px;height:2px;background:var(--volt);box-shadow:0 0 6px var(--volt-glow);}
.hero-eyebrow span{font-family:var(--mono);font-size:10px;color:var(--volt);letter-spacing:3px;text-transform:uppercase;}
.hero-title{font-size:clamp(28px,4vw,54px);font-weight:900;text-transform:uppercase;letter-spacing:-0.5px;line-height:1;color:var(--text);}
.hero-title span{color:var(--volt);}
.hero-sub{font-size:14px;font-weight:300;color:var(--text2);margin-top:12px;line-height:1.6;max-width:520px;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:var(--ff);font-weight:700;letter-spacing:1.5px;text-transform:uppercase;border:none;cursor:pointer;transition:all .2s;text-decoration:none;white-space:nowrap;}
.btn-volt{background:var(--volt);color:var(--ink);padding:11px 24px;font-size:12px;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));box-shadow:0 0 20px var(--volt-glow);}
.btn-volt:hover{background:#33d5f7;box-shadow:0 0 30px var(--volt-glow);transform:translateY(-1px);}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--wire);padding:9px 18px;font-size:11px;border-radius:2px;}
.btn-ghost:hover{border-color:var(--wire2);color:var(--text);}


/* ══════════════════════════════════════
   1. PARTNERS PAGE
══════════════════════════════════════ */
.partners-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:var(--wire);border:1px solid var(--wire);margin:40px 0;}
.pstat{background:var(--ink1);padding:28px 24px;text-align:center;}
.pstat-val{font-size:40px;font-weight:900;color:var(--text);line-height:1;}
.pstat-val span{font-size:20px;color:var(--volt);}
.pstat-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);margin-top:6px;}
.pstat-note{font-family:var(--mono);font-size:10px;color:var(--text3);margin-top:3px;}

/* Partner tiers */
.partner-section{margin-bottom:56px;}
.partner-tier-head{display:flex;align-items:center;gap:16px;margin-bottom:24px;}
.tier-badge{padding:4px 14px;font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:1px solid;border-radius:2px;}
.tier-gold{color:var(--amber);border-color:var(--amber);background:rgba(255,184,0,0.08);}
.tier-silver{color:var(--text2);border-color:var(--wire2);background:var(--ink2);}
.tier-bronze{color:#cd7f32;border-color:#cd7f32;background:rgba(205,127,50,0.08);}
.tier-line{flex:1;height:1px;background:var(--wire);}
.tier-count{font-family:var(--mono);font-size:10px;color:var(--text3);}

.partners-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.partner-card{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;overflow:hidden;transition:border-color .2s,transform .2s,box-shadow .2s;cursor:pointer;}
.partner-card:hover{border-color:var(--wire2);transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,0.4);}
.partner-card-top{padding:28px 24px;display:flex;align-items:flex-start;gap:18px;border-bottom:1px solid var(--wire);}
.partner-logo-big{width:56px;height:56px;background:var(--steel);border:1px solid var(--wire2);border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--mono);font-size:14px;font-weight:700;color:var(--volt);}
.partner-info{}
.partner-name{font-size:18px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--text);margin-bottom:3px;}
.partner-country{font-family:var(--mono);font-size:10px;color:var(--text3);margin-bottom:8px;}
.partner-specialties{display:flex;flex-wrap:wrap;gap:5px;}
.spec-tag{font-family:var(--mono);font-size:9px;padding:2px 8px;border:1px solid var(--wire2);color:var(--text3);border-radius:2px;}
.partner-card-bottom{padding:14px 24px;display:flex;align-items:center;justify-content:space-between;}
.partner-cert-count{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;color:var(--text3);}
.partner-cert-count svg{color:var(--volt);}
.partner-since{font-family:var(--mono);font-size:10px;color:var(--text3);}
.partner-link{font-family:var(--mono);font-size:10px;color:var(--volt);transition:opacity .15s;}
.partner-link:hover{opacity:.7;}

/* Certificates grid */
.certs-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:40px;}
.cert-card{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;padding:24px 20px;display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center;transition:border-color .2s;}
.cert-card:hover{border-color:var(--wire2);}
.cert-seal{width:64px;height:64px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;position:relative;}
.cert-seal::after{content:'';position:absolute;inset:4px;border-radius:50%;border:1px dashed;opacity:.4;}
.cert-seal.gold{border-color:var(--amber);} .cert-seal.gold::after{border-color:var(--amber);}
.cert-seal.cyan{border-color:var(--volt);} .cert-seal.cyan::after{border-color:var(--volt);}
.cert-seal.lime{border-color:var(--lime);} .cert-seal.lime::after{border-color:var(--lime);}
.cert-seal.violet{border-color:var(--violet);} .cert-seal.violet::after{border-color:var(--violet);}
.cert-name{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text);}
.cert-issuer{font-family:var(--mono);font-size:10px;color:var(--text3);}
.cert-year{font-family:var(--mono);font-size:10px;color:var(--volt);}


/* ══════════════════════════════════════
   2. CATALOG PAGE
══════════════════════════════════════ */
.catalog-layout{display:grid;grid-template-columns:260px 1fr;gap:20px;padding:32px 0 80px;align-items:start;}

/* Filter sidebar */
.filter-panel{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;overflow:hidden;position:sticky;top:72px;}
.filter-head{padding:14px 18px;background:var(--steel);border-bottom:1px solid var(--wire);display:flex;align-items:center;justify-content:space-between;}
.filter-title{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);}
.filter-reset{font-family:var(--mono);font-size:10px;color:var(--volt);cursor:pointer;background:none;border:none;transition:opacity .15s;}
.filter-reset:hover{opacity:.7;}

.filter-group{border-bottom:1px solid var(--wire);}
.filter-group-head{padding:12px 18px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;transition:background .15s;}
.filter-group-head:hover{background:var(--ink2);}
.filter-group-label{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);}
.filter-group-arrow{color:var(--text3);transition:transform .2s;}
.filter-group.open .filter-group-arrow{transform:rotate(180deg);}
.filter-group-body{padding:10px 18px 14px;display:none;}
.filter-group.open .filter-group-body{display:block;}

.filter-check{display:flex;align-items:center;gap:10px;padding:6px 0;cursor:pointer;}
.filter-check input{display:none;}
.fc-box{width:14px;height:14px;border:1px solid var(--wire2);background:var(--ink);border-radius:2px;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.filter-check input:checked+.fc-box{background:var(--volt);border-color:var(--volt);}
.fc-label{font-size:12px;color:var(--text2);transition:color .15s;flex:1;}
.filter-check:hover .fc-label{color:var(--text);}
.fc-count{font-family:var(--mono);font-size:10px;color:var(--text3);}

/* Price range */
.price-range{display:flex;flex-direction:column;gap:10px;}
.price-inputs{display:flex;gap:8px;align-items:center;}
.price-input{background:var(--ink2);border:1px solid var(--wire);color:var(--text);font-family:var(--mono);font-size:11px;padding:7px 10px;border-radius:2px;outline:none;width:100%;transition:border-color .2s;}
.price-input:focus{border-color:var(--volt);}
.price-sep{color:var(--text3);font-size:12px;flex-shrink:0;}
input[type=range]{-webkit-appearance:none;width:100%;height:3px;background:var(--wire);border-radius:2px;outline:none;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:var(--volt);cursor:pointer;border:2px solid var(--ink);box-shadow:0 0 8px var(--volt-glow);}

/* Catalog main */
.catalog-main{}
.catalog-toolbar{display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;}
.catalog-search{position:relative;flex:1;min-width:200px;}
.catalog-search input{width:100%;background:var(--ink1);border:1px solid var(--wire);border-radius:3px;color:var(--text);font-family:var(--mono);font-size:12px;padding:10px 36px 10px 14px;outline:none;transition:border-color .2s,box-shadow .2s;}
.catalog-search input::placeholder{color:var(--text3);}
.catalog-search input:focus{border-color:var(--volt);box-shadow:0 0 0 3px var(--volt-lo);}
.search-ico{position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--text3);}
.catalog-sort{background:var(--ink1);border:1px solid var(--wire);color:var(--text2);font-family:var(--mono);font-size:11px;padding:10px 14px;border-radius:3px;outline:none;cursor:pointer;}
.catalog-count{font-family:var(--mono);font-size:11px;color:var(--text3);}

/* Active filters */
.active-filters{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;}
.af-pill{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;color:var(--volt);background:var(--volt-lo);border:1px solid rgba(0,200,240,0.2);padding:3px 10px;border-radius:2px;cursor:pointer;transition:background .15s;}
.af-pill:hover{background:var(--volt-med);}
.af-x{opacity:.6;}

/* Product grid */
.products-list{display:flex;flex-direction:column;gap:10px;}
.prod-row{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;display:grid;grid-template-columns:64px 1fr auto;gap:0;overflow:hidden;transition:border-color .2s,transform .15s;cursor:pointer;}
.prod-row:hover{border-color:var(--wire2);transform:translateX(2px);}
.prod-row-thumb{background:var(--ink2);border-right:1px solid var(--wire);display:flex;align-items:center;justify-content:center;padding:0;}
.prod-row-body{padding:16px 20px;display:flex;flex-direction:column;justify-content:space-between;gap:6px;}
.prod-row-head{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.prod-row-name{font-size:15px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text);}
.prod-row:hover .prod-row-name{color:var(--volt);}
.prod-row-vendor{font-family:var(--mono);font-size:10px;color:var(--text3);}
.prod-row-tags{display:flex;gap:5px;flex-wrap:wrap;}
.prod-row-tag{font-family:var(--mono);font-size:9px;padding:2px 7px;border:1px solid var(--wire2);color:var(--text3);border-radius:2px;}
.prod-row-desc{font-size:12px;color:var(--text2);line-height:1.5;}
.prod-row-right{padding:16px 20px;display:flex;flex-direction:column;align-items:flex-end;justify-content:space-between;border-left:1px solid var(--wire);min-width:160px;}
.prod-row-price{font-size:18px;font-weight:800;color:var(--text);}
.prod-row-price span{font-size:12px;color:var(--volt);}
.prod-row-pnote{font-family:var(--mono);font-size:9px;color:var(--text3);margin-top:2px;text-align:right;}
.prod-row-btns{display:flex;flex-direction:column;gap:6px;width:100%;}
.btn-kp{background:var(--volt);color:var(--ink);border:none;padding:7px 12px;font-family:var(--ff);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;width:100%;transition:background .15s;}
.btn-kp:hover{background:#33d5f7;}
.btn-more{background:transparent;color:var(--text2);border:1px solid var(--wire);padding:6px 12px;font-family:var(--ff);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;width:100%;transition:all .15s;}
.btn-more:hover{border-color:var(--wire2);color:var(--text);}

/* Status badge */
.status-dot{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:9px;}
.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.dot-green{background:var(--lime);}
.dot-amber{background:var(--amber);}
.dot-red{background:var(--crimson);}

/* Pagination */
.pagination{display:flex;align-items:center;gap:6px;margin-top:24px;justify-content:center;}
.pg-btn{width:34px;height:34px;background:var(--ink1);border:1px solid var(--wire);color:var(--text2);font-family:var(--mono);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;border-radius:2px;}
.pg-btn:hover{border-color:var(--wire2);color:var(--text);}
.pg-btn.active{background:var(--volt-lo);border-color:var(--volt);color:var(--volt);}


/* ══════════════════════════════════════
   3. MAP PAGE
══════════════════════════════════════ */
.map-layout{display:grid;grid-template-columns:1fr 320px;gap:20px;padding:32px 0 80px;align-items:start;}

/* SVG Russia Map */
.map-container{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;overflow:hidden;position:relative;}
.map-toolbar{padding:14px 18px;background:var(--steel);border-bottom:1px solid var(--wire);display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.map-title-bar{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);}
.map-legend{display:flex;gap:16px;margin-left:auto;}
.legend-item{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;color:var(--text3);}
.legend-dot{width:10px;height:10px;border-radius:50%;}

.map-svg-wrap{position:relative;padding:24px;}
#russia-map{width:100%;height:auto;display:block;}

/* Map pins */
.map-pin{cursor:pointer;transition:transform .2s;}
.map-pin:hover{transform:scale(1.2);}
.pin-outer{fill:none;stroke-width:1;}
.pin-inner{opacity:.9;}
.pin-label{font-family:'JetBrains Mono',monospace;font-size:9px;fill:#6a8aaa;pointer-events:none;}

/* Tooltip */
.map-tooltip{position:absolute;background:var(--steel);border:1px solid var(--wire2);border-radius:3px;padding:10px 14px;pointer-events:none;opacity:0;transition:opacity .2s;z-index:10;min-width:180px;box-shadow:0 8px 24px rgba(0,0,0,.5);}
.map-tooltip.show{opacity:1;}
.tt-city{font-size:13px;font-weight:700;text-transform:uppercase;color:var(--text);margin-bottom:4px;}
.tt-count{font-family:var(--mono);font-size:11px;color:var(--volt);margin-bottom:6px;}
.tt-projects{display:flex;flex-direction:column;gap:3px;}
.tt-project{font-family:var(--mono);font-size:10px;color:var(--text3);}

/* Map sidebar */
.map-sidebar{display:flex;flex-direction:column;gap:14px;}

.map-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.mstat{background:var(--ink1);border:1px solid var(--wire);padding:16px;text-align:center;}
.mstat-val{font-size:28px;font-weight:900;color:var(--text);line-height:1;}
.mstat-val span{font-size:14px;color:var(--volt);}
.mstat-label{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);margin-top:4px;}

.projects-feed{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;overflow:hidden;}
.feed-head{padding:12px 16px;background:var(--steel);border-bottom:1px solid var(--wire);display:flex;align-items:center;justify-content:space-between;}
.feed-title{font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);}
.live-indicator{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:9px;color:var(--lime);}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--lime);animation:blink-g 1.2s ease-in-out infinite;}
@keyframes blink-g{0%,100%{opacity:1}50%{opacity:.2}}

.feed-items{max-height:400px;overflow-y:auto;}
.feed-item{padding:12px 16px;border-bottom:1px solid rgba(25,45,72,.5);cursor:pointer;transition:background .15s;}
.feed-item:last-child{border-bottom:none;}
.feed-item:hover{background:var(--ink2);}
.fi-header{display:flex;align-items:flex-start;gap:8px;margin-bottom:6px;}
.fi-city-dot{width:8px;height:8px;border-radius:50%;margin-top:3px;flex-shrink:0;}
.fi-info{}
.fi-city{font-size:12px;font-weight:700;color:var(--text);letter-spacing:.5px;}
.fi-industry{font-family:var(--mono);font-size:9px;color:var(--text3);margin-top:1px;}
.fi-project{font-size:12px;color:var(--text2);line-height:1.4;padding-left:16px;}
.fi-meta{display:flex;align-items:center;gap:8px;margin-top:4px;padding-left:16px;}
.fi-product{font-family:var(--mono);font-size:9px;color:var(--volt);}
.fi-year{font-family:var(--mono);font-size:9px;color:var(--text3);}

.region-list{background:var(--ink1);border:1px solid var(--wire);border-radius:4px;overflow:hidden;}
.rl-head{padding:12px 16px;background:var(--steel);border-bottom:1px solid var(--wire);}
.rl-title{font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);}
.rl-items{padding:8px 0;}
